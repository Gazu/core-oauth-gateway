# Service identity

# Logical service name included in structured logs and response headers.
SERVICE_NAME=core-oauth-gateway

# Deployed service version included in structured logs and response headers.
SERVICE_VERSION=0.2.0

# Authentication-provider validation

# Global maximum lifetime accepted for user JWTs issued by a login provider.
AUTH_PROVIDER_JWT_MAX_TTL_SECONDS=300

# OAuth token and request lifetimes

# Default access-token lifetime when the OAuth client has no database override.
ACCESS_TOKEN_TTL_SECONDS=300

# Authorization-code and oauth_key signature lifetime.
AUTH_CODE_TTL_SECONDS=60

# Pushed Authorization Request request_uri lifetime.
REQUEST_URI_TTL_SECONDS=60

# Default refresh-token lifetime when the OAuth client has no database override.
REFRESH_TOKEN_TTL_SECONDS=3600

# Supabase connectivity

# Base URL of the Supabase project used for production OAuth persistence.
SUPABASE_URL=https://PROJECT_REF.supabase.co

# Server-only service_role key. Never expose it through a NEXT_PUBLIC variable.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Encryption at rest

# Secret used to encrypt OAuth signing private keys before storing them in Supabase.
SIGNING_KEY_ENCRYPTION_SECRET=<long-random-secret>

# Secret used to encrypt access and refresh token values stored in Supabase.
OAUTH_TOKEN_ENCRYPTION_SECRET=<long-random-secret>

# Signing-key lifecycle

# Number of days before the active OAuth signing key is rotated.
SIGNING_KEY_ROTATION_DAYS=30

# Number of days retired signing keys remain available for JWT verification.
SIGNING_KEY_RETENTION_DAYS=45

# Number of seconds signing-key material may remain in the process cache.
SIGNING_KEY_CACHE_SECONDS=60

# OAuth persistence caches and cleanup

# Number of seconds OAuth client and authentication-provider records are cached.
OAUTH_CLIENT_CACHE_SECONDS=60

# Minimum interval between automatic Supabase cleanup RPC executions.
SUPABASE_CLEANUP_INTERVAL_SECONDS=300

# Retention period for expired token rows before cleanup permanently deletes them.
SUPABASE_EXPIRED_TOKEN_RETENTION_SECONDS=604800

# Functional audit persistence

# Controls writes to oauth_audit_events: all, errors_only, or disabled.
# Audit lifecycle logs remain enabled in every mode.
OAUTH_AUDIT_PERSISTENCE_MODE=all

# Maximum time allowed for one oauth_audit_events insert before it is abandoned.
OAUTH_AUDIT_TIMEOUT_MS=2000

# Optional Resource Owner Password grant

# Enables the legacy password grant. Keep disabled outside controlled environments.
OAUTH_PASSWORD_GRANT_ENABLED=false

# JSON map of password-grant users. Define only when the password grant is enabled.
# OAUTH_PASSWORD_USERS_JSON={"user":{"password":"<password>","claims":{"sub":"user"}}}

# Structured logging and tracing

# Minimum emitted log level.
LOG_LEVEL=INFO

# Logger delivery mode: async for production throughput or sync for local testing.
LOGGER_MODE=async

# Fraction of eligible log events emitted, from 0 to 1.
LOGGER_SAMPLE_RATE=1

# Enables internal logger metrics collection.
LOGGER_INTERNAL_METRICS_ENABLED=false

# Maximum number of events waiting in the asynchronous logger queue.
LOGGER_MAX_QUEUE_SIZE=10000

# Interval in milliseconds between asynchronous logger flushes.
LOGGER_FLUSH_INTERVAL_MS=10

# Behavior when the logger queue is full.
LOGGER_OVERFLOW_STRATEGY=sync-fallback

# Maximum time in milliseconds allowed to flush logs during shutdown.
LOGGER_SHUTDOWN_TIMEOUT_MS=2000

# Includes exception stack traces in error logs when enabled.
LOGGER_ERROR_STACK_ENABLED=false
